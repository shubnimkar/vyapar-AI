  const validation = validatePhoneNumber(phoneNumber, language);
  if (!validation.valid) {
    return {
      success: false,
      error: validation.error,
    };
  }

  const formattedPhone = validation.formatted!;

  // DEMO MODE: Skip SMS sending, just return success
  console.log('[Auth Manager] DEMO MODE: Skipping SMS send, use OTP 123456');
  
  // Record send time for cooldown tracking
  recordOTPSend(formattedPhone);
  
  // Reset verification attempts for new OTP
  resetVerificationAttempts(formattedPhone);
  
  return {
    success: true,
  };

  /* PRODUCTION CODE - COMMENTED OUT FOR DEMO
  // Check rate limit (3 attempts per hour)
  const rateLimit = checkRateLimit(formattedPhone);
  if (!rateLimit.allowed) {
    const minutes = Math.ceil(rateLimit.retryAfter! / 60);
    const errorMessages: Record<Language, string> = {
      en: `Too many attempts. Please try again in ${minutes} minutes`,
      hi: `बहुत अधिक प्रयास। कृपया ${minutes} मिनट में पुनः प्रयास करें`,
      mr: `खूप प्रयत्न. कृपया ${minutes} मिनिटांनी पुन्हा प्रयत्न करा`,
    };
    
    return {
      success: false,
      error: errorMessages[language],
      retryAfter: rateLimit.retryAfter,
    };
  }

  // Send OTP via Supabase Auth
  const result = await SupabaseAuth.signInWithOtp(formattedPhone);

  if (result.success) {
    // Record send time for cooldown tracking
    recordOTPSend(formattedPhone);
    
    // Reset verification attempts for new OTP
    resetVerificationAttempts(formattedPhone);
  }

  return result;
  */
}

/**
 * Verify OTP code
 * Includes attempt limiting
 * DEMO MODE: Accepts "1234" as bypass OTP
 */
export async function verifyOTP(
  phoneNumber: string,
  code: string,
  rememberDevice: boolean = false,
  language: Language = 'en'
): Promise<AuthResult> {
  // Validate phone number
  const validation = validatePhoneNumber(phoneNumber, language);
  if (!validation.valid) {
    return {
      success: false,
      error: validation.error,
    };
  }

  const formattedPhone = validation.formatted!;

  // DEMO MODE: Bypass with OTP "123456"
  if (code === '123456') {
    console.log('[Auth Manager] DEMO MODE: Bypassing OTP verification with code 123456');
    
    // Create a demo session
    const demoSession: Session = {
      accessToken: 'demo-token-' + Date.now(),
      refreshToken: 'demo-refresh-' + Date.now(),
      expiresAt: Date.now() + (24 * 60 * 60 * 1000), // 24 hours
      user: {
        id: 'demo-user-' + formattedPhone.replace(/\D/g, ''),
        phoneNumber: formattedPhone,
        createdAt: new Date().toISOString(),
      },
    };
    
    // Save session to localStorage
    AuthSessionStore.saveSession(demoSession, rememberDevice);
    
    // Reset rate limit and attempts
    resetRateLimit(formattedPhone);
    resetVerificationAttempts(formattedPhone);
    resetResendCooldown(formattedPhone);
    
    // In demo mode, always return isFirstLogin as true
    // The login page will check the profile API to determine actual status
    return {
      success: true,
      session: demoSession,
      user: demoSession.user,
      isFirstLogin: true,
    };
  }

  // Check verification attempts (5 attempts per OTP)
  const attempts = checkVerificationAttempts(formattedPhone, code);
  if (!attempts.allowed) {
    const errorMessages: Record<Language, string> = {
      en: 'Too many incorrect attempts. Please request a new OTP',
      hi: 'बहुत अधिक गलत प्रयास। कृपया नया OTP अनुरोध करें',
      mr: 'खूप चुकीचे प्रयत्न. कृपया नवीन OTP विनंती करा',
    };
    
    return {
      success: false,
      error: errorMessages[language],
    };
  }

  // Verify OTP via Supabase Auth
  const result = await SupabaseAuth.verifyOtp(formattedPhone, code);

  if (result.success && result.session) {
    // Save session to localStorage with remember device preference
    AuthSessionStore.saveSession(result.session, rememberDevice);
    
    // Reset rate limit and attempts on successful verification
    resetRateLimit(formattedPhone);
    resetVerificationAttempts(formattedPhone);
    resetResendCooldown(formattedPhone);

    // Check if this is first login (migration needed)
    const isFirstLogin = !AuthSessionStore.isMigrationCompleted();

    return {
      success: true,
      session: result.session,
      user: result.session.user,
      isFirstLogin,
    };
  }

  return {
    success: false,
    error: result.error,
  };
}

/**
 * Resend OTP
 * Includes cooldown check
 */
export async function resendOTP(
  phoneNumber: string,
  language: Language = 'en'
): Promise<OTPResult> {
  // Validate phone number
  const validation = validatePhoneNumber(phoneNumber, language);
  if (!validation.valid) {
    return {
      success: false,
      error: validation.error,
    };
  }

  const formattedPhone = validation.formatted!;

  // Check resend cooldown (60 seconds)
  const cooldown = checkResendCooldown(formattedPhone);
  if (!cooldown.canResend) {
    const errorMessages: Record<Language, string> = {
      en: `Please wait ${cooldown.secondsRemaining} seconds before resending`,
      hi: `पुनः भेजने से पहले ${cooldown.secondsRemaining} सेकंड प्रतीक्षा करें`,
      mr: `पुन्हा पाठवण्यापूर्वी ${cooldown.secondsRemaining} सेकंद प्रतीक्षा करा`,
    };
    
    return {
      success: false,
      error: errorMessages[language],
      retryAfter: cooldown.secondsRemaining,
    };
  }

  // Use sendOTP which includes rate limiting
  return sendOTP(formattedPhone, language);
}

// ============================================
// Session Management
// ============================================

/**
 * Get current session
 * Checks localStorage and validates
 */
export async function getSession(): Promise<AuthResult> {
  // Load session from localStorage
  const storedSession = AuthSessionStore.loadSession();
  
  if (!storedSession) {
    return {
      success: false,
      error: 'No active session',
    };
  }
  
  // Validate session
  if (!AuthSessionStore.isSessionValid(storedSession)) {
    // Session expired - clear it
    AuthSessionStore.clearSession();
    return {
      success: false,
      error: 'Session expired',
    };
  }
  
  // Check if session should be refreshed
  if (AuthSessionStore.shouldRefresh(storedSession)) {
    console.log('[Auth Manager] Session expiring soon, refreshing...');
    return refreshSession();
  }
  
  return {
    success: true,
    session: storedSession,
    user: storedSession.user,
  };
}

/**
 * Refresh session token
 * Extends session expiry
 */
export async function refreshSession(): Promise<AuthResult> {
  const result = await SupabaseAuth.refreshSession();
  
  if (result.success && result.session) {
    // Save refreshed session to localStorage
    const rememberDevice = AuthSessionStore.shouldRememberDevice();
    AuthSessionStore.saveSession(result.session, rememberDevice);
    
    return {
      success: true,
      session: result.session,
      user: result.session.user,
    };
  }
  
  // Refresh failed - clear session
  AuthSessionStore.clearSession();
  
  return {
    success: false,
    error: result.error || 'Failed to refresh session',
  };
}

/**
 * Logout current user
 * Clears session and invalidates token
 */
export async function logout(): Promise<OTPResult> {
  // Sign out from Supabase
  const result = await SupabaseAuth.signOut();
  
  // Clear local session regardless of Supabase result
  AuthSessionStore.clearSession();
  
  return result;
}

/**
 * Check if user is authenticated
 */
export function isAuthenticated(): boolean {
  const storedSession = AuthSessionStore.loadSession();
  return AuthSessionStore.isSessionValid(storedSession);
}

/**
 * Get current user
 */
export function getCurrentUser(): User | null {
  const storedSession = AuthSessionStore.loadSession();
  
  if (!storedSession || !AuthSessionStore.isSessionValid(storedSession)) {
    return null;
  }
  
  return storedSession.user;
}

// ============================================
// Export all functions
// ============================================

export const AuthManager = {
  // Phone validation
  validatePhoneNumber,
  formatPhoneNumber,
  formatPhoneForDisplay,
  maskPhoneNumber,
  
  // OTP operations
  sendOTP,
  verifyOTP,
  resendOTP,
  
  // Session management
  getSession,
  refreshSession,
  logout,
  isAuthenticated,
  getCurrentUser,
  
  // Rate limiting
  checkRateLimit,
  resetRateLimit,
  
  // Verification attempts
  checkVerificationAttempts,
  resetVerificationAttempts,
  
  // Resend cooldown
  checkResendCooldown,
  recordOTPSend,
  resetResendCooldown,
};
